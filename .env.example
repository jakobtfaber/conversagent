# ─── Cartesia (required) ─────────────────────────────────────────────────────
# Used for both STT (ink-whisper) and TTS (sonic-3)
# Get your key at: https://play.cartesia.ai/keys
CARTESIA_API_KEY=your_cartesia_api_key_here

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Set to "anthropic" (default) or "google"
LLM_PROVIDER=anthropic

# ─── Anthropic (required if LLM_PROVIDER=anthropic) ──────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: override the model (default: claude-sonnet-4-5-20250929)
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ─── Google Gemini (required if LLM_PROVIDER=google) ─────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
# Optional: override the model (default: gemini-1.5-flash)
# GOOGLE_MODEL=gemini-1.5-flash
